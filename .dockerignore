# Docker ignore — Brand Guardian AI
# ─────────────────────────────────────────────────────────────
# NOTE: cookies.txt is intentionally ignored here.
# It is injected securely at runtime via AWS Secrets Manager 
# (YOUTUBE_COOKIES_B64) into the container.
# ─────────────────────────────────────────────────────────────

ComplianceQAPipeline/cookies.txt


# Version control
.git
.gitignore

# Local virtual environments
.venv
ComplianceQAPipeline/.venv

# Python bytecode
__pycache__
*.pyc
*.pyo
*.pyd

# Local environment file (secrets must come from ECS task definition / Secrets Manager)
.env

# Editor / IDE
.vscode
.idea

# Python version pin (not needed in container)
.python-version

# Lock files (dependencies installed from pyproject.toml directly)
uv.lock

# Node (not used in production)
node_modules
frontend/node_modules

# Logs and temp files
*.log
temp_*.mp4
temp_*.mp3

# Test/dev artifacts
*.pytest_cache
.pytest_cache
htmlcov
.coverage
