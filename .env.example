# AZURE STORAGE
AZURE_STORAGE_CONNECTION_STRING = "DefaultEndpointsProtocol=https;AccountName=<your-account>;AccountKey=<your-key>;EndpointSuffix=core.windows.net"

# AZURE OPENAI CONFIG
AZURE_OPENAI_API_KEY = "<your-key>"
AZURE_OPENAI_ENDPOINT = "https://<your-resource>.cognitiveservices.azure.com/"
AZURE_OPENAI_API_VERSION = "2024-12-01-preview"
AZURE_OPENAI_CHAT_DEPLOYMENT = "gpt-4o"

# EMBEDDING MODEL CONFIG
AZURE_OPENAI_EMBEDDING_DEPLOYMENT = "text-embedding-3-small"

# AZURE AI SEARCH -- KNOWLEDGE BASE CONFIG
AZURE_SEARCH_ENDPOINT = "https://<your-service>.search.windows.net"
AZURE_SEARCH_API_KEY = "<your-key>"
AZURE_SEARCH_INDEX_NAME = "brand-guardian-index"

# AZURE VIDEO INDEXER CONFIG
AZURE_VI_NAME = "yt-video-indexer"
AZURE_VI_LOCATION = "eastus"
AZURE_VI_ACCOUNT_ID = "<your-account-id>"
AZURE_SUBSCRIPTION_ID = "<your-sub-id>"
AZURE_RESOURCE_GROUP = "<your-rg>"

# AZURE MONITORING - OBSERVABILITY
APPLICATIONINSIGHTS_CONNECTION_STRING = "InstrumentationKey=<your-key>;..."

# LANGSMITH TRACING
LANGCHAIN_TRACING_V2 = true
LANGCHAIN_ENDPOINT = "https://api.smith.langchain.com"
LANGCHAIN_API_KEY = "<your-key>"
LANGCHAIN_PROJECT = "brand-guardian-prod"

# TAVILY WEB SEARCH
TAVILY_API_KEY = "<your-key>"

# YT-DLP BOT BYPASS
YOUTUBE_COOKIES_FILE = "ComplianceQAPipeline/cookies.txt"

# GENERAL
APP_ENV = development
LOG_LEVEL = INFO
ALLOWED_ORIGINS = http://localhost:8000
